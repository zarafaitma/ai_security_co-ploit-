print("=== ROUTE D alt trigger: subdomains <domain> (plural) ===")
before = at.session_state["total_scans"]
send("subdomains example.net")
assert at.session_state["total_scans"] == before + 1
row = last_history_row()
assert row[1] == "example.net" and row[2] == "Subdomain Discovery", row
print("PASS:", row)

print("\n=== REGRESSION: ROUTE 7 (fullscan) still works, unaffected by new elif chain ===")
before = at.session_state["total_scans"]
send("fullscan example.com")
assert at.session_state["total_scans"] == before + 3, "ROUTE 7 should still add +3 to total_scans"
row = last_history_row()
assert row[2] == "Automated Chain Scan", row
print("PASS:", row)

print("=== REGRESSION: ROUTE 1 (header) still works ===")
before = at.session_state["total_scans"]
send("header example.com")
# header route increments total_scans by 1 only if captured_raw is non-empty;
# curl isn't expected to succeed in this sandbox, so just confirm no crash
# and that it did NOT get routed into ROUTE A/B/C/D by mistake.
row_task_names_before = [r[2] for r in at.session_state["history"][:1]]
print("PASS (no exception, ROUTE 1 still reachable)")

print("=== REGRESSION: ROUTE 8 fallback still reaches the LLM for unrelated chat ===")
msgs_before = len(at.session_state["messages"])
send("hello, what can you help me with?")
assert len(at.session_state["messages"]) == msgs_before + 2  # user + assistant
last_msg = at.session_state["messages"][-1]["content"]
assert "STUB-LLM-RESPONSE" in last_msg, f"Expected fallback to reach the LLM stub, got: {last_msg}"
print("PASS: general chat still reaches llm.invoke()")

print("\nALL HOTFIX ROUTE TESTS PASSED")

import os
db_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "security_copilot.db")
if os.path.exists(db_path):
    os.remove(db_path)

import database
database.create_database()
database.create_user("tester", "TestPass123!", "admin")

from streamlit.testing.v1 import AppTest

at = AppTest.from_file("app.py")
at.run()
at.text_input[0].set_value("tester")
at.text_input[1].set_value("TestPass123!")
at.button[0].click().run()
assert not at.exception, f"Exception on login: {at.exception}"
assert at.session_state["authenticated"] is True

def send(prompt):
    at.chat_input[0].set_value(prompt).run()
    assert not at.exception, f"Exception on prompt '{prompt}': {at.exception}"

def last_history_row():
    return at.session_state["history"][0]

def llm_was_called_for(prompt_substring):
    # Our stub records every prompt forwarded to llm.invoke(); ROUTE A-D must
    # NEVER reach that path, so this checks none of the recorded prompts
    # contain the raw command text (a loose but effective signal).
    return any(prompt_substring in p for p in at.session_state.get("_llm_invoke_log", []))

print("=== ROUTE A: scan <ip> -> run_nmap, not LLM ===")
before = at.session_state["total_scans"]
send("scan 192.168.1.1")
assert at.session_state["total_scans"] == before + 1
row = last_history_row()
assert row[1] == "192.168.1.1" and row[2] == "Direct Nmap Scan", row
assert len(at.code) >= 1, "Expected st.code() output for nmap result"
print("PASS:", row)

print("=== ROUTE B: whois <domain> -> run_whois, not LLM ===")
before = at.session_state["total_scans"]
send("whois example.com")
assert at.session_state["total_scans"] == before + 1
row = last_history_row()
assert row[1] == "example.com" and row[2] == "WHOIS Lookup", row
print("PASS:", row)

print("=== ROUTE C: dig <domain> -> run_dig, not LLM ===")
before = at.session_state["total_scans"]
send("dig example.com")
assert at.session_state["total_scans"] == before + 1
row = last_history_row()
assert row[1] == "example.com" and row[2] == "DNS Dig Query", row
print("PASS:", row)

print("=== ROUTE C alt trigger: dns <domain> -> run_dig ===")
before = at.session_state["total_scans"]
send("dns example.org")
assert at.session_state["total_scans"] == before + 1
row = last_history_row()
assert row[1] == "example.org" and row[2] == "DNS Dig Query", row
print("PASS:", row)

print("=== ROUTE D: subdomain <domain> -> run_subdomain_brute_force, dataframe shown ===")
before = at.session_state["total_scans"]
send("subdomain example.com")
assert at.session_state["total_scans"] == before + 1
row = last_history_row()
assert row[1] == "example.com" and row[2] == "Subdomain Discovery", row
assert len(at.dataframe) >= 1, "Expected st.dataframe() output for subdomain results"
